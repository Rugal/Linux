  "contextWeighting": {
    "strategy": "time-decay-with-relevance",
    "parameters": {
      "recentSessionsWeight": 1.0,
      "decayHalfLife": 3.0,
      "deprecatedContentWeight": 0.05,
      "activeRevisionsWeight": 0.9
    },
    "currentWeights": {}
  },
  "loadRecommendations": {
    "quick": {
      "items": [],
      "totalTokens": 0,
      "loadTime": "0s"
    },
    "standard": {
      "items": [],
      "totalTokens": 0,
      "loadTime": "0s"
    },
    "full": {
      "note": "Include all contexts including deprecated",
      "totalTokens": 0,
      "loadTime": "0s"
    }
  },
  "deprecated": {
    "contexts": []
  },
  "autoCheckpointConfig": {
    "enabled": true,
    "triggers": [
      {
        "type": "turn-count",
        "threshold": 25,
        "action": "prompt-user"
      },
      {
        "type": "time-duration",
        "threshold": "90 minutes",
        "action": "prompt-user"
      },
      {
        "type": "milestone-detected",
        "patterns": [
          "section completed",
          "design approved"
        ],
        "action": "prompt-user-strong"
      },
      {
        "type": "document-modified",
        "files": [
          "requirements.md",
          "design.md",
          "tasks.md"
        ],
        "action": "suggest-checkpoint"
      },
      {
        "type": "context-switch",
        "patterns": [
          "切换",
          "先放一下"
        ],
        "action": "prompt-user-strong"
      }
    ],
    "promptStyle": "gentle",
    "cooldownMinutes": 20
  }
}